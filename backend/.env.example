# Copy to backend/.env and fill in real values. NEVER commit backend/.env.
# The app refuses to start if any secret still contains "replace_me".

# ---- Mode ----
# true = Alpaca paper + Polymarket Amoy testnet (recommended for dev)
# false = REAL MONEY. Requires typed confirmation in UI to flip.
PAPER_MODE=true

# ---- Server ----
# Host 0.0.0.0 if you want to reach it from other devices on the LAN.
APP_HOST=0.0.0.0
APP_PORT=3003
DATABASE_URL=sqlite+aiosqlite:///./autotrader.sqlite
# Generate with: openssl rand -hex 32
# Frontend uses this same value as NEXT_PUBLIC_API_KEY.
JWT_SECRET=replace_me_with_openssl_rand_hex_32
JWT_EXPIRES_MINUTES=1440

# CORS — comma-separated origins the frontend may call from. Add your
# LAN IP (e.g. http://192.168.1.10:3010) when running the dashboard from
# another device on the same network.
CORS_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# ---- AI provider switch ----
# "openrouter" (hosted) or "lmstudio" (local, free, private).
AI_PROVIDER=lmstudio

# ---- AI (OpenRouter) ----
# Get a key at https://openrouter.ai/keys. Any model slug works for CLAUDE_MODEL
# (e.g. anthropic/claude-sonnet-4.5, openai/gpt-4o, google/gemini-2.5-pro).
OPENROUTER_API_KEY=replace_me
CLAUDE_MODEL=anthropic/claude-sonnet-4.5

# ---- AI (LM Studio) ----
# Load a model via `lms load <id>` then set LMSTUDIO_MODEL to the identifier
# LM Studio assigned (see `lms ps`). Example: qwen3.6-35b-a3b, qwen/qwen3-coder-30b.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=qwen3.6-35b-a3b

# ---- Alpaca (US stocks) ----
# Generate at https://alpaca.markets (free paper account available)
ALPACA_API_KEY=replace_me
ALPACA_API_SECRET=replace_me
# Paper: https://paper-api.alpaca.markets   Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# ---- Polymarket ----
# EXPERIMENTAL adapter — keep disabled until the loop is validated. With
# POLYMARKET_ENABLED=false the broker factory returns a NullBroker that
# can't place orders, even if a private key is present.
POLYMARKET_ENABLED=false
# Polygon EOA private key (0x + 64 hex chars). Use a FRESH wallet dedicated
# to this app. For dev use Amoy testnet; faucet: https://faucet.polygon.technology/
POLYMARKET_PRIVATE_KEY=replace_me
# CLOB API creds are DERIVED one-time by signing a message with the wallet
# via py-clob-client. Leave blank on first boot; the app will derive and
# print them once, then paste them back here.
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_SECRET=
POLYMARKET_CLOB_PASSPHRASE=
# https://clob.polymarket.com (mainnet)  /  https://clob-staging.polymarket.com (testnet if available)
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# 137 = Polygon mainnet, 80002 = Amoy testnet
POLYMARKET_CHAIN_ID=80002

# ---- News (optional; improves AI context) ----
FINNHUB_API_KEY=
POLYGON_API_KEY=

# ---- Web search (optional; the researcher calls web_search for news,
# competitor discovery, macro context). Tried in order before falling
# back to keyless DuckDuckGo HTML scraping, which is flaky. Setting any
# ONE of these makes web_search reliable.
#   Tavily:  https://tavily.com            (1000 free searches/mo, LLM-tuned summaries)
#   Brave:   https://brave.com/search/api  (2000 free/mo)
#   Serper:  https://serper.dev            (2500 free queries, Google results)
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=

# ---- Trading loop cadence ----
STOCK_DECISION_INTERVAL_MIN=5
POLYMARKET_DECISION_INTERVAL_MIN=15
RUNTIME_MONITOR_INTERVAL_SEC=30

# ---- Watchlist + strategy guidance ----
# STOCK_STRATEGY_NOTE is injected verbatim into the decision prompt. Use
# it to tell the AI what kind of trader you want it to be.
STOCK_WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,AMD,TSLA,META,GOOGL,AMZN
STOCK_STRATEGY_NOTE=Momentum day-trading on liquid US equities.

# ---- Advanced: agent toggles (defaults are sane — tweak for tuning) ----
# Scout loop: fast-cadence discovery (gainers / losers / most active).
SCOUT_ENABLED=true
SCOUT_INTERVAL_MIN=2
SCOUT_LLM_ENABLED=false            # LLM refinement of scout output; costs ~1 tiny call/tick
SCOUT_QUEUE_MAX_SIZE=50
SCOUT_QUEUE_TTL_SEC=600
SCOUT_PER_BUCKET=5

# Position-review loop: LLM pass over each open position, tightens stops
# or exits early on fresh news, independent of the decision loop cadence.
POSITION_REVIEW_ENABLED=true
POSITION_REVIEW_INTERVAL_SEC=90

# Post-mortem: one LLM call per closed trade, writes a structured lesson.
POST_MORTEM_ENABLED=true

# Macro regime: one call per session open; caches risk-on/off/volatile/ranging
# label that stock prompts inject. One LLM call per day.
MACRO_REGIME_ENABLED=true

# Research: lets the decision agent call web_search / fetch_url / SEC
# filings before proposing. Off = faster, cheaper, less informed.
RESEARCH_ENABLED=true
RESEARCH_MAX_TOOL_CALLS=6
RESEARCH_MAX_ROUNDS=8
# Per-tool-result char cap (~4 chars per token) before it enters the
# LLM's message history. Sized for the recommended 256 K context load.
# Smaller loads just trigger the shrink-and-retry path transparently.
#   Smaller model (32-64 K loaded):   16000
#   Mid model  (128 K loaded):        65536   (default)
#   Max model  (262144 K loaded):     131072
# LM Studio's context ceiling is set at load time via
# `lms load --context-length N`; see README for the full recipe.
RESEARCH_TOOL_RESULT_CHARS=65536

# Multi-agent: fan out per-symbol research agents before the decision
# agent sees their aggregated findings. Higher quality, higher cost.
MULTI_AGENT_ENABLED=false
MULTI_AGENT_FOCUS_COUNT=3
MULTI_AGENT_PER_AGENT_TOOL_CALLS=6
MULTI_AGENT_PER_AGENT_ROUNDS=8

# ---- Advanced: budget + safety ----
# Daily LLM spend ceiling (USD). Scout + decision + review loops skip
# ticks once today's total cost crosses this. 0 = no cap.
DAILY_LLM_BUDGET_USD=0.0

# Auto-pause the agent mesh after N consecutive losing closes in a day.
# 0 disables. Independent of the kill switch.
CIRCUIT_BREAKER_CONSECUTIVE_LOSSES=3

# Auto-close option positions when nearest leg's DTE is <= this. 0 disables.
OPTION_DTE_WATCHDOG_DAYS=1

# When true, scout + decision + monitor skip their tick while the US
# equity market is closed. Turn off for 24/7 debugging / dry runs.
RESPECT_MARKET_HOURS=true

# ---- Advanced: screener ----
SCREENER_TOP_K=10
SCREENER_MIN_PRICE=5.0
SCREENER_MIN_PREV_VOLUME=500000
